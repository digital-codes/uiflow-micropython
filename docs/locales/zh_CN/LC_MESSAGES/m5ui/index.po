msgstr ""

#: ../../source/m5ui/index.rst:100 77453b8907264cbea9357aee64228673
msgid ""
"``M5.Lcd.drawString()`` / ``M5.Widgets`` English text -> "
"``M5.Lcd.FONTS.Montserrat*``"
